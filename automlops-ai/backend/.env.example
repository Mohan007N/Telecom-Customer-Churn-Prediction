# Application
APP_NAME=AutoMLOps AI
APP_VERSION=1.0.0
DEBUG=True
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/automlops
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/automlops

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000

# File Storage
UPLOAD_DIR=./datasets
MODEL_DIR=./models
REPORT_DIR=./reports

# LLM Configuration
LLM_MODEL_NAME=Qwen/Qwen2.5-7B-Instruct-AWQ
LLM_DEVICE=cuda
LLM_MAX_LENGTH=2048

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
